MARKET_INTEL_ENV=local
MARKET_INTEL_SYMBOL=BTC/USDT
MARKET_INTEL_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
MARKET_INTEL_EXCHANGE=binance
MARKET_INTEL_TIMEFRAME=5m
DATABASE_URL=postgresql://market:market@postgres:5432/market_intel
REDIS_URL=redis://redis:6379/0
COLLECTOR_INTERVAL_SECONDS=60
RESEARCH_INTERVAL_SECONDS=300
MARKET_INTEL_MAX_CANDLE_ROWS_PER_SYMBOL=1200
MARKET_INTEL_MAX_CONTEXT_ROWS_PER_SYMBOL=1500
MARKET_INTEL_MAX_SIGNAL_ROWS=750
MARKET_INTEL_MAX_PAPER_TRADE_ROWS=1000
MARKET_INTEL_MAX_DAILY_REPORT_ROWS=100
MARKET_INTEL_MAX_SYSTEM_LOG_ROWS=500
MARKET_INTEL_MAX_FORWARD_SIGNAL_ROWS=750
MARKET_INTEL_MAX_FORWARD_RESULT_ROWS=750
NEWS_API_ENABLED=false
ONCHAIN_API_ENABLED=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-strong-password
# Session cookie expires when the browser session is closed. Server-side max age is a fallback.
DASHBOARD_SESSION_SECONDS=86400
# Set true only after HTTPS is enabled.
DASHBOARD_COOKIE_SECURE=false
# Optional: comma-separated public IPs for your devices. Leave empty if your IPs change often.
DASHBOARD_ALLOWED_IPS=
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_CONFIDENCE=0.60
TELEGRAM_NOTIFIER_INTERVAL_SECONDS=5
